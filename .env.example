# Contextual AI Configuration
CONTEXTUAL_API_KEY=your_api_key_here
CONTEXTUAL_DATASTORE_ID=your_datastore_id_here

# Optional: Create a new datastore if ID not provided
# CONTEXTUAL_DATASTORE_NAME=context-crew-blogs

# Scraping Configuration
SCRAPE_DELAY_SECONDS=2
MAX_ARTICLES_PER_SOURCE=50
REQUEST_TIMEOUT_SECONDS=30

# Storage Configuration
LOCAL_DATA_DIR=./data/raw
ENABLE_HTML_SNAPSHOTS=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
DRY_RUN=false
SKIP_UPLOAD=false
FORCE_RESCRAPE=false
